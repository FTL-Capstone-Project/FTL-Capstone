// Orbis data model — mirrors project_plan.md §5.
// Global indicators (shared threat intel) + per-org reviews (private verdicts).
// Owner: Michael (schema/migrations); shape agreed with David (§5).
//
// TWO LAYERS:
//   GLOBAL   → Indicator: one row per unique URL (canonicalKey), scanned once, shared by everyone.
//   PER-ORG  → Submission / OrgReview / Campaign / Notification: isolated by orgId.
// Individuals have orgId = null and no OrgReview layer.
//
// SCORE DIRECTION: aiScore / humanScore are a 0-100 SAFETY score (100 = safe, 0 = dangerous).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         Int      @id @default(autoincrement())
  clerkOrgId String   @unique
  name       String
  createdAt  DateTime @default(now())

  users      User[]
  orgReviews OrgReview[]
  campaigns  Campaign[]
}

model User {
  id          Int      @id @default(autoincrement())
  clerkUserId String   @unique
  orgId       Int? // null = individual (no org)
  email       String   @unique // copied from Clerk; used to match forwarded emails
  name        String?
  role        String   @default("individual") // individual | member | analyst
  // Opt-out for the emailed report we send after a forwarded-email check finishes. Default true =
  // opted in (no behavior change for existing users); set false to get in-app notifications only.
  emailReports Boolean @default(true)
  // SHA-256 hash of the user's browser-extension API key (never the raw key). Null = no key
  // issued yet. Unique so a presented key resolves to exactly one user; rotating overwrites it,
  // which instantly invalidates the old key (per-user revocation). See services/apiKey.js.
  apiKeyHash  String?  @unique
  createdAt   DateTime @default(now())

  organization  Organization?  @relation(fields: [orgId], references: [id])
  submissions   Submission[]
  notifications Notification[]
  reviews       OrgReview[]    @relation("ReviewedBy") // reviews this analyst authored

  @@index([orgId])
  @@index([email])
}

model Submission {
  id          Int      @id @default(autoincrement())
  userId      Int
  orgId       Int? // null = reported as an individual
  indicatorId Int
  rawUrl      String
  contextText String?
  source      String   @default("web") // web | email
  escalated   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  @@index([userId])
  @@index([orgId])
  @@index([indicatorId])
}

// GLOBAL — one row per unique URL, scanned once, shared by everyone.
model Indicator {
  id              Int      @id @default(autoincrement())
  canonicalKey    String   @unique // dedup key (host + path + semantic params), globally unique
  domain          String
  status          String   @default("pending") // pending | scanning | done | error
  aiScore         Int? // 0-100 SAFETY score (100 = safe)
  aiVerdict       String? // Claude plain-English explanation (shared)
  aiConfidence    String? // low | medium | high
  aiTitle         String? // short headline for the Reports card, e.g. "Fake PayPal login"
  aiDescription   String? // one-sentence summary under the title
  aiTags          Json? // category chips, e.g. ["Credential phishing","Impersonation"]
  aiReasons       Json? // "why" rows: [{ text, severity: safe|review|dangerous }]
  screenshotUrl   String? // from urlscan.io
  urlscanUuid     String?
  finalUrl        String? // where the link ACTUALLY landed after redirects (urlscan page.url)
  finalHost       String? // just the landing host, e.g. "amazon.com" (for the "goes to X" UI cue)
  redirectedToDifferentHost Boolean @default(false) // did it leave the domain it started on?
  domainAgeDays   Int?
  blacklistHit    Boolean  @default(false) // Google Safe Browsing known-bad?
  blacklistSource String? // e.g. google_safe_browsing:SOCIAL_ENGINEERING
  reportCount     Int      @default(0) // total submissions across all orgs + individuals
  // Global "a user reported this verdict for review" flow (VerdictCard "Report it").
  // Because indicators are GLOBAL, a report escalates to a (portrayed) global security
  // team review. Lifecycle: null = not reported · "pending review" · "confirmed safe" ·
  // "confirmed dangerous". reportedCount = how many users flagged it. Additive/nullable
  // so this migration can't disturb existing rows.
  globalReviewStatus String? // null | pending review | confirmed safe | confirmed dangerous
  reportedCount      Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions   Submission[]
  orgReviews    OrgReview[]
  notifications Notification[]
  reportReasons ReportReason[]

  @@index([domain])
  @@index([status])
}

// One user's "Report it" on an indicator, with their free-text WHY (≤200 words, capped server-side).
// Feeds the (portrayed) global security team's triage: many reasons across many users on the same
// indicator = a signal to look. reportedCount on Indicator is the fast counter; this holds the text.
model ReportReason {
  id          Int      @id @default(autoincrement())
  indicatorId Int
  userId      Int?     // who reported (null-safe for dev-stub / anonymous)
  reason      String   // the user's explanation of why they're reporting
  createdAt   DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id])

  @@index([indicatorId])
}

// PER-ORG overlay — each org's private authoritative verdict on a global indicator.
model OrgReview {
  id           Int      @id @default(autoincrement())
  orgId        Int
  indicatorId  Int
  humanScore   Int? // analyst's authoritative 0-100 safety score
  humanVerdict String?
  reviewStatus String   @default("pending review") // pending review | investigating | confirmed malicious | confirmed safe
  // Privacy gate: an analyst must EXPLICITLY flag a review as shareable before it
  // shows up in the org's Team History. Defaults to false (private) so nothing with
  // personal info leaks to the whole team without a deliberate analyst decision.
  sharedWithOrg Boolean @default(false)
  reviewedBy   Int? // FK → User.id (which analyst)
  campaignId   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization   Organization @relation(fields: [orgId], references: [id])
  indicator      Indicator    @relation(fields: [indicatorId], references: [id])
  campaign       Campaign?    @relation(fields: [campaignId], references: [id])
  reviewedByUser User?        @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@unique([orgId, indicatorId])
  @@index([orgId])
  @@index([indicatorId])
  @@index([campaignId])
  @@index([reviewStatus])
  @@index([sharedWithOrg])
}

model Campaign {
  id           Int      @id @default(autoincrement())
  orgId        Int
  name         String
  sharedSignal String?
  firstSeen    DateTime @default(now())
  lastSeen     DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  orgReviews   OrgReview[]

  @@index([orgId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  indicatorId Int?
  type        String // e.g. verdict_confirmed
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  indicator Indicator? @relation(fields: [indicatorId], references: [id])

  @@index([userId])
  @@index([isRead])
}
