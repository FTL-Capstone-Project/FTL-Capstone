{
  "name": "@orbis/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/index.js",
    "start": "node --env-file-if-exists=.env src/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node src/prisma/seed.js",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:build": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@clerk/express": "^2.1.36",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "svix": "^1.96.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
