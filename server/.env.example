# ── Orbis server env — copy to server/.env (gitignored) and fill in ──

# Postgres connection string. Local example:
#   postgresql://USER:PASSWORD@localhost:5432/orbis?schema=public
# Or a free hosted DB (Neon/Supabase/Render). Required for migrate/seed/run.
DATABASE_URL=

# ── Clerk (backend) ──
# Secret key (sk_...) — server-only, NEVER exposed to the browser.
CLERK_SECRET_KEY=
# Publishable key (pk_...) — used by @clerk/express to verify tokens.
CLERK_PUBLISHABLE_KEY=
# Signing secret (whsec_...) from the Clerk webhook endpoint config.
CLERK_WEBHOOK_SECRET=

# ── Scanning / AI ──
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
# OpenAI key (sk-proj-...) — used for verdict generation, Ask Orbo chat, vision, NLP insights.
# LLM_BASE_URL and LLM_MODEL are optional overrides (default: api.openai.com/v1, gpt-4o-mini).
OPENAI_API_KEY=

# ── Server ──
PORT=3001
# Where the client runs (for CORS). Vite dev default:
CLIENT_URL=http://localhost:5173
# Browser-extension origin(s) allowed to call the API (CORS), comma-separated. Get the id from
# chrome://extensions after "Load unpacked". Leave empty if you're not running the extension.
# EXTENSION_ORIGINS=chrome-extension://abcdefghijklmnopabcdefghijklmnop

# ── Local dev only ──
# If you build WITHOUT Clerk keys, set this to 1 to allow the dev-stub (fakes one
# logged-in user). Auth FAILS CLOSED (401) unless this is explicitly "1", so a real
# deploy that forgot its Clerk keys can never silently expose the API. Leave unset
# in production.
ORBIS_DEV_STUB=1
