# ── Orbis server env — copy to server/.env (gitignored) and fill in ──

# Postgres connection string. Local example:
#   postgresql://USER:PASSWORD@localhost:5432/orbis?schema=public
# Or a free hosted DB (Neon/Supabase/Render). Required for migrate/seed/run.
DATABASE_URL=

# ── Clerk (backend) ──
# Secret key (sk_...) — server-only, NEVER exposed to the browser.
CLERK_SECRET_KEY=
# Publishable key (pk_...) — used by @clerk/express to verify tokens.
CLERK_PUBLISHABLE_KEY=
# Signing secret (whsec_...) from the Clerk webhook endpoint config.
CLERK_WEBHOOK_SECRET=

# ── Scanning / AI (David's slice — stubbed until keys exist) ──
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
ANTHROPIC_API_KEY=

# ── Server ──
PORT=3001
# Where the client runs (for CORS). Vite dev default:
CLIENT_URL=http://localhost:5173
