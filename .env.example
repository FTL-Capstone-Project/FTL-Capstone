# ─────────────────────────────────────────────────────────────
# Orbis environment variables — copy this file to `.env` and fill in.
# NEVER commit the real `.env` (it's gitignored). This file is the
# single source of truth for what secrets the app needs.
# ─────────────────────────────────────────────────────────────

# ── Database (server) ──
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/orbis"

# ── Clerk auth (both) ── https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY="pk_test_..."     # client uses this (as VITE_CLERK_PUBLISHABLE_KEY)
CLERK_SECRET_KEY="sk_test_..."          # server only
CLERK_WEBHOOK_SECRET="whsec_..."        # server only — verifies the Clerk → us webhook

# ── External APIs (server) ──
URLSCAN_API_KEY="..."                   # https://urlscan.io/user/profile/
GOOGLE_SAFE_BROWSING_KEY="..."          # https://console.cloud.google.com (Safe Browsing API)
ANTHROPIC_API_KEY="sk-ant-..."          # https://console.anthropic.com — Claude verdicts

# ── Inbound email forwarding (server, optional) ── see DEPLOY.md Step 7
INBOUND_EMAIL_TOKEN="..."               # shared secret the Gmail Apps Script relay sends as x-orbis-token
INBOUND_EMAIL_TOKENS=""                 # optional plus-token map "david:david@acme.com,..."

# ── Outbound report email (server, optional) ── see DEPLOY.md Step 8
# The reverse Gmail + Apps Script relay: the server POSTs report JSON to OUR Apps Script Web App,
# which emails the report from orbischecks@gmail.com. Both must be set or report emails stay off.
OUTBOUND_EMAIL_URL=""                   # our Apps Script Web App URL (https://script.google.com/…)
OUTBOUND_EMAIL_TOKEN="..."              # shared secret sent in the POST body

# ── Client → server wiring ──
VITE_API_URL="http://localhost:3001"    # where the client finds the server
