{
  "manifest_version": 3,
  "name": "Orbis — Check with Orbo",
  "version": "0.2.0",
  "description": "Orbo checks your email for phishing: an instant safe/warning/danger read when you open a message, plus a right-click check on any link or sender.",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://orbis-api-z4vx.onrender.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content-gmail.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Orbis"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
