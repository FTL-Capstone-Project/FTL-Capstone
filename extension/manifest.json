{
  "manifest_version": 3,
  "name": "Orbis — Check with Orbo",
  "version": "0.1.0",
  "description": "Right-click any link and check it for phishing with Orbis. Reuses the Orbis check-link API.",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["http://localhost:3001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Orbis"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
